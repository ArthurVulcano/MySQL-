Atividade 1:

SELECT CustomerName AS 'Nome'
FROM Customers LIKE '%'
ORDER BY CustomerName ASC;

Atividade 2:

SELECT City AS 'Cidade',
			CustomerName AS 'NomeCustomizado'
FROM Customers
WHERE City LIKE '%or%'
ORDER BY City, CustomerName;

Atividade 3:

SELECT CustomerName AS 'NomeCliente',
       Country AS 'Pais',
       PostalCode AS 'CEP'
FROM Customers
WHERE Country LIKE 'FRA%'
ORDER BY PostalCode ASC;

Atividade 4:

SELECT ContactName AS 'NomeCLiente',
						Country AS 'Pais',
							City AS 'Cidade'
FROM Customers
WHERE Country LIKE '%a'
AND ContactName LIKE 'a%'
ORDER BY Country, City, ContactName ASC;

Atividade 5:

SELECT CustomerName AS 'NomeCustomizado',
					City AS 'Cidade'
FROM Customers
WHERE City LIKE 'BERl%'
ORDER BY CustomerName ASC;
Atividade 6:

SELECT CustomerName AS 'NomeCliente',
					Country AS 'Pais'
FROM Customers
WHERE Country LIKE '%SA%'
ORDER BY Country DESC;
Atividade 7:

SELECT ContactName AS 'NomeCliente',
					CustomerID AS 'IDCLIENTE'
FROM Customers
WHERE ContactName LIKE 'A%'
ORDER BY CustomerID;

